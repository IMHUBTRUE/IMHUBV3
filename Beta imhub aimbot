-- Drag helpers: allow dragging window by header area? -> only window is draggable (headerDecor preserved as fixed visual)
do
    header.Active = true header.Selectable = true
    local function makeDraggable(guiObject)
        guiObject.Active = true
        local dragging = false
        local dragInput = nil
        local dragStart = nil
        local startPos = nil
        local function update(input)
            local delta = input.Position - dragStart
            guiObject.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
            -- when window moves, we do NOT move logoBtn (it's fixed). That's intended.
        end
        guiObject.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = guiObject.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        guiObject.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input == dragInput then update(input) end
        end)
    end
    pcall(function()
        -- make the window draggable but NOT the headerDecor or logoBtn
        makeDraggable(win)
        -- make floating buttons draggable
        makeDraggable(camLockFloatBtn)
        makeDraggable(jumpFloatBtn)
        -- do NOT make logoBtn draggable; it's fixed in logoGui
    end)
end

