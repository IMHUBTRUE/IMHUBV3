-- Main loop
RunService.RenderStepped:Connect(function()
    -- Indicator
    if _G.aimbot_indicator_enabled and indicatorGui and not destroyedUi then
        local viewport = Camera.ViewportSize
        local minSide = math.min(viewport.X, viewport.Y)
        local fov = clamp((_G.aimbot_fov or 120), 5, 360)
        local fraction = (fov / 360) * 2
        fraction = clamp(fraction, 0.05, 1.5)
        local baseRadius = (minSide * 0.45) * (fraction)
        local radius = math.max(6, math.floor(baseRadius * (_G.aimbot_indicator_scale or 1)))
        indicatorFrame.Size = UDim2.new(0, radius*2, 0, radius*2)
        indicatorFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
        indicatorFrame.AnchorPoint = Vector2.new(0.5, 0.5)
        indicatorGui.Enabled = true
    else
        if indicatorGui then indicatorGui.Enabled = false end
    end

    -- Aimbot
    local shouldAim = _G.aimbot_enabled and (not _G.aimbot_hold_to_aim or aimHoldActive)
    if shouldAim then
        local target = findAimbotTarget()
        if target and target.pos then
            local camPos = Camera.CFrame.Position
            local desired = CFrame.new(camPos, target.pos)
            local alpha = (_G.aimbot_smooth_enabled and (_G.aimbot_smooth or 0.25)) or 1
            alpha = clamp(alpha, 0, 1)
            Camera.CFrame = Camera.CFrame:Lerp(desired, alpha)
        end
    else
        if camLockActive and camLockTarget and camLockTarget ~= lp and camLockTarget.Character and camLockTarget.Character:FindFirstChild("Head") then
            local headPos = camLockTarget.Character.Head.Position
            local camPos = Camera.CFrame.Position
            Camera.CFrame = CFrame.new(camPos, headPos)
        end
    end

    -- speed / noclip / jump held / jump toggle
    if lp.Character and lp.Character:FindFirstChild("Humanoid") then
        local hum = lp.Character.Humanoid
        hum.WalkSpeed = (_G.speedEnabled and _G.speedValue) or 16

        for _,v in pairs(lp.Character:GetDescendants()) do
            if v:IsA("BasePart") then
                if _G.noclipEnabled then
                    v.CanCollide = false
                else
                    if v.Name == "HumanoidRootPart" then v.CanCollide = true else v.CanCollide = false end
                end
            end
        end

        -- if user enabled the jump toggle, continuously apply jump (as requested)
        if jumpToggleEnabled then
            hum.UseJumpPower = true
            hum.JumpPower = _G.jumpValue
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        elseif jumpHeld then
            hum.UseJumpPower = true
            hum.JumpPower = _G.jumpValue
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end

    -- ESP update
    if espEnabled then
        for _,plr in pairs(Players:GetPlayers()) do
            if plr ~= lp and plr.Character and plr.Character:FindFirstChild("Head") then
                if not (_G.esp_ignore_teams and lp.Team and plr.Team and lp.Team == plr.Team) then
                    if espBoxMode then
                        if not espBoxes[plr] then createESPBoxFor(plr) end
                    else
                        if not espLabels[plr] then createESPFor(plr) end
                    end
                else
                    if espLabels[plr] then removeESPFor(plr) end
                    if espBoxes[plr] then removeESPBoxFor(plr) end
                end
            end
        end

        for plr,data in pairs(espLabels) do
            if plr and data and data.label and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character:FindFirstChild("Head") and lp.Character and lp.Character:FindFirstChild("Head") then
                local dist = math.floor((lp.Character.Head.Position - plr.Character.Head.Position).Magnitude)
                local hp = math.floor(plr.Character.Humanoid.Health)
                data.label.Text = string.format("%s • HP: %d • %dm", plr.Name, hp, dist)
            else
                removeESPFor(plr)
            end
        end

        for plr,data in pairs(espBoxes) do
            if plr and data and data.box and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character:FindFirstChild("Head") and lp.Character and lp.Character:FindFirstChild("Head") then
                -- We could update color/size dynamically here; keep static outline for now
                local hp = math.floor(plr.Character.Humanoid.Health)
                data.box.BorderColor3 = (hp <= 0) and Color3.fromRGB(140,140,140) or Color3.fromRGB(255,100,140)
            else
                removeESPBoxFor(plr)
            end
        end
    else
        for plr,_ in pairs(espLabels) do removeESPFor(plr) end
        for plr,_ in pairs(espBoxes) do removeESPBoxFor(plr) end
    end
end)

