-- Aimbot helpers
local function getTargetPartFromCharacter(char)
    if not char then return nil end
    if _G.aimbot_target_part == "Head" and char:FindFirstChild("Head") then return char.Head end
    if _G.aimbot_target_part == "UpperTorso" then
        if char:FindFirstChild("UpperTorso") then return char.UpperTorso
        elseif char:FindFirstChild("Torso") then return char.Torso end
    end
    if _G.aimbot_target_part == "HumanoidRootPart" and char:FindFirstChild("HumanoidRootPart") then return char.HumanoidRootPart end
    return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
end

local function findAimbotTarget()
    local camPos = Camera.CFrame.Position
    local camLook = Camera.CFrame.LookVector
    local best, bestScore = nil, math.huge
    local halfFov = (_G.aimbot_fov or 120) * 0.5
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= lp and plr.Character and plr.Character.Parent then
            if (not _G.aimbot_ignore_teams) and lp.Team and plr.Team and lp.Team == plr.Team then
                -- skip teammate when NOT ignoring teams
            else
                local part = getTargetPartFromCharacter(plr.Character)
                if part then
                    local dir = (part.Position - camPos)
                    if dir.Magnitude > 0 then
                        local dot = clamp((dir.Unit):Dot(camLook), -1, 1)
                        local angle = math.deg(math.acos(dot))
                        if angle <= halfFov then
                            if _G.aimbot_target_mode == "Closest" then
                                if dir.Magnitude < bestScore then bestScore = dir.Magnitude; best = {player = plr, pos = part.Position} end
                            else
                                local score = angle * 1000 + dir.Magnitude
                                if score < bestScore then bestScore = score; best = {player = plr, pos = part.Position} end
                            end
                        end
                    end
                end
            end
        end
    end
    return best
end

